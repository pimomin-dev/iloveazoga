rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'pimo.min@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Toppings
    match /toppings/{toppingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['items', 'total', 'status', 'timestamp']) &&
               data.items is list &&
               data.total is number &&
               data.status in ['pending', 'preparing', 'completed', 'cancelled'] &&
               data.timestamp is timestamp;
      }

      allow create: if isValidOrder(request.resource.data);
      allow get: if true; // Allow customers to check their order status by ID
      allow list: if isAdmin(); // Only admins can see all orders
      allow update: if isAdmin() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if false;
    }
    
    // Admins collection (protected)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through Firebase Console or by existing admins (not implemented here)
    }
  }
}
